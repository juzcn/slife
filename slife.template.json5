{
  // ── Environment Variables ──────────────────────────────────────
  // ${VAR} references resolve at runtime: shell → OS keyring → default.
  //
  // IMPORTANT: Plaintext API keys are REJECTED at startup.
  // All api_key fields MUST use ${VAR} references (e.g. ${DEEPSEEK_API_KEY}).
  // Store the actual key via credstore (never paste keys here):
  //   credstore set DEEPSEEK_API_KEY
  env: {
    BAIDU_API_KEY: "${BAIDU_API_KEY}",
    // SERPER_API_KEY: "${SERPER_API_KEY}",
  },

  // ── Agent Behavior ─────────────────────────────────────────────
  agent: {
    max_iterations: 10,
    context_floor: 0.2,   // trigger trim at 20% remaining
    context_ceiling: 0.8, // trim down to 80% of window
  },

  // ── Subagent ───────────────────────────────────────────────────
  // Local child processes for parallel work. Always available.
  subagent: {
    max_subagents: 5,
    task_timeout: 120,
  },

  // ── MQTT / A2A Mesh ────────────────────────────────────────────
  // Multi-agent communication.  Requires paho-mqtt + Mosquitto.
  // Start Mosquitto BEFORE launching slife — its presence is the
  // on/off switch.  agent_id is derived from --agent (default "slife").
  // agent_name is an optional human-readable display name.
  mqtt: {
    // agent_name: "my-agent",   // optional display name
    broker: { host: "localhost", port: 1883 },
    heartbeat_interval: 15,
    heartbeat_timeout: 45,
    task_timeout: 120,
  },

  // ── Model Provider ─────────────────────────────────────────────
  // Edit for your API provider.  Default uses DeepSeek — replace
  // with OpenAI, Gemini, Ollama, or any OpenAI-compatible endpoint.
  //
  // api_key MUST be a ${VAR} reference — plaintext keys are REJECTED.
  // ${DEEPSEEK_API_KEY} resolves from keyring automatically.
  // Store the key first:  credstore set DEEPSEEK_API_KEY
  models: {
    mode: "merge",
    providers: {
      deepseek: {
        base_url: "https://api.deepseek.com",
        api_key: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            model: "deepseek-v4-flash",
            name: "DeepSeek V4 Flash",
            reasoning: true,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
          {
            model: "deepseek-v4-pro",
            name: "DeepSeek V4 Pro",
            reasoning: true,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
        ],
      },
    },
  },
  active_model: "deepseek/deepseek-v4-flash",

  // ── MCP Servers ────────────────────────────────────────────────
  // Add any MCP-compatible server here (Python, Node, Go, Rust).
  mcp: {
    servers: {
      filesystem: {
        command: "npx",
        args: ["-y", "@modelcontextprotocol/server-filesystem", "."],
        description: "Local filesystem — read, write, list, search files.",
      },
      fetch: {
        command: "uvx",
        args: ["mcp-server-fetch"],
        description: "Fetch and convert web pages to markdown.",
      },
      "duckduckgo-search": {
        command: "uvx",
        args: [
          "--with", "duckduckgo-mcp-server[browser]",
          "duckduckgo-mcp-server",
          "--fetch-backend", "auto",
          "--search-backend", "auto",
        ],
        description: "DuckDuckGo web search. No API key required.",
      },
      // serper: {
      //   command: "npx",
      //   args: ["-y", "serper-search-scrape-mcp-server"],
      //   env: { SERPER_API_KEY: "${SERPER_API_KEY}" },
      //   description: "Google web search via Serper. Set SERPER_API_KEY first.",
      // },
    },
  },

  // ── CLI Tools ──────────────────────────────────────────────────
  // External commands the agent discovers and persists at runtime.
  cli_tools: {
    uv: {
      command: "uv",
      description: "Fast Python package manager. Subcommands: uv pip install, uv venv, uv init, uv add, uv run, uv sync, uv tool install.",
      install: "curl -LsSf https://astral.sh/uv/install.sh | sh",
    },
    uvx: {
      command: "uvx",
      description: "Run Python CLI tools without installing (like npx for Python). Usage: uvx ruff check ., uvx black file.py.",
      install: "Bundled with uv.",
    },
  },

  // ── Memory ─────────────────────────────────────────────────────
  // Always on — DB auto-located at ~/.slife/<agent_id>.db.
  // Embedding config is optional; without it keyword search still works.
  memory: {
    // Local GGUF embeddings (offline).  Install: slife[embeddings]
    // embedding: {
    //   model: "bge-m3",
    //   gguf_path: "/path/to/bge-m3-Q4_K_M.gguf",
    //   dim: 1024,
    // },
  },
}
