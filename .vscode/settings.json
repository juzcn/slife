{
  "files.associations": {
    "*.json5": "json5",
    "*.j2": "jinja"
  },
  "[json5]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jinja]": {
    "editor.wordWrap": "on"
  },
  "[log]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  }
}
