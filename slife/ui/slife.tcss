/* ═══════════════════════════════════════════════════════════════════
   slife TUI — Claude Code CLI style
   Dark minimal theme with warm amber accents.
   ═══════════════════════════════════════════════════════════════════ */

/* ── Screen ──────────────────────────────────────────────────── */

Screen {
    background: #0d1117;
    color: #e6edf3;
}

/* ── Chat view (main scrollable area) ────────────────────────── */

ChatView {
    overflow-y: auto;
    padding: 0;
    scrollbar-size: 0 0;
    scrollbar-color: #30363d;
    scrollbar-color-hover: #484f58;
}

/* ── User messages — ">" style ───────────────────────────────── */

.user-message {
    margin: 1 0 0 0;
    padding: 0 1;
    color: #e6edf3;
}

.user-message > Static {
    width: 100%;
}

/* ── Assistant messages — clean, no label ────────────────────── */

.assistant-message {
    margin: 0 0 1 0;
    padding: 0 1;
    color: #e6edf3;
}

/* ── Thinking block inside assistant messages ────────────────── */

.thinking-block {
    color: #6e7681;
    text-style: italic;
    margin: 0 0 1 0;
    padding: 0 1;
}

/* ── System messages ─────────────────────────────────────────── */

.system-message {
    margin: 0 0;
    padding: 0 1;
    color: #6e7681;
    text-style: italic;
}

/* ── Tool call display ───────────────────────────────────────── */

.tool-call {
    margin: 0 1 1 2;
    padding: 0 1;
    border: solid #30363d;
    background: #161b22;
    color: #e6edf3;
    height: auto;
    min-height: 1;
    overflow: hidden;
}

/* ── Input (bottom docked) ────────────────────────────────────── */

#user-input {
    dock: bottom;
    width: 100%;
    height: 3;
    padding: 1 1;
    background: #0d1117;
    color: #e6edf3;
    border: none;
    border-top: solid #30363d;
}

#user-input:focus {
    border: none;
}

#user-input > .input--placeholder {
    color: #484f58;
}

/* ── Status bar (bottom docked, below input) ─────────────────── */

StatusBar {
    dock: bottom;
    height: 1;
    background: #161b22;
    color: #6e7681;
    padding: 0 1;
    text-style: none;
}
