{
  // ═══════════════════════════════════════════════════════════════
  // slife Configuration — OpenClaw-compatible JSON5 format
  // ═══════════════════════════════════════════════════════════════
  // API keys: set as environment variables, reference with ${VAR}.

  // ── Environment variables ────────────────────────────────────
  // Set here to make them available to tools and shell commands.

  env: {
    SERPER_API_KEY: "${SERPER_API_KEY}",
    // BAIDU_API_KEY: "your-baidu-api-key",
  },

  // ── Agent defaults ───────────────────────────────────────────

  agent: {
    max_iterations: 10,

  },

  // ── Models ───────────────────────────────────────────────────
  // model = API model name (doubles as local identifier, unique within provider)
  // name  = display label

  models: {
    mode: "merge",

    providers: {
      deepseek: {
        base_url: "https://api.deepseek.com",
        api_key: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",

        models: [
          {
            model: "deepseek-v4-flash",
            name: "DeepSeek V4 Flash",
            reasoning: false,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
          {
            model: "deepseek-v4-pro",
            name: "DeepSeek V4 Pro",
            reasoning: true,
            // reasoning_effort: "high",
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
        ],
      },
    },
  },

  active_model: "deepseek/deepseek-v4-pro",

  // ── Tools ────────────────────────────────────────────────────

  tools: [
    { type: "serper" },
    { type: "shell", timeout: 30 },
    { type: "skill", skills_dir: "skills" },
  ],
}
