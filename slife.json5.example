{
  // ═══════════════════════════════════════════════════════════════
  // slife — Minimum Bootstrap Configuration
  // ═══════════════════════════════════════════════════════════════
  // Copy to slife.json5 and edit.  The only key you need is your
  // LLM provider's API key — everything else is optional and can
  // be added later at runtime by the agent.

  // ── Environment variables ────────────────────────────────────
  // Injected into os.environ. Use ${VAR} syntax in mcp servers.
  env: {
    // GITHUB_TOKEN: "${GITHUB_TOKEN}",
    // SERPER_API_KEY: "${SERPER_API_KEY}",
  },

  // ── Agent ────────────────────────────────────────────────────
  agent: {
    max_iterations: 10,

    // Context window management — keeps the active conversation
    // within 20%-80% of the model's context window. When the
    // conversation exceeds context_ceiling (80%), the oldest
    // turns are trimmed down to context_floor (20%).
    // Trimmed content stays in permanent memory and can be
    // recalled via memory_search when needed.
    context_floor: 0.2,
    context_ceiling: 0.8,
    // Max single tool result = tool_result_ceiling × context_window.
    // 0.2 means a tool result can use at most 20% of context.
    // Set 0 to disable (no limit — dangerous for large files).
    tool_result_ceiling: 0.2,
  },

  // ── Models ───────────────────────────────────────────────────
  // provider: connection shared by all models under it.
  //   model:   API model id (also used as lookup key).
  //   name:    display label shown in the TUI status bar.
  //   reasoning: true → enable extended thinking.
  //   input:   ["text", "image"] → vision (/file attach).
  models: {
    mode: "merge",
    providers: {
      deepseek: {
        base_url: "https://api.deepseek.com",
        api_key: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            model: "deepseek-v4-flash",
            name: "DeepSeek V4 Flash",
            reasoning: false,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
          },
          {
            model: "deepseek-v4-pro",
            name: "DeepSeek V4 Pro",
            reasoning: true,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
          },
        ],
      },
      // openai: {
      //   base_url: "https://api.openai.com/v1",
      //   api_key: "${OPENAI_API_KEY}",
      //   api: "openai-completions",
      //   models: [
      //     { model: "gpt-4o", name: "GPT-4o" },
      //   ],
      // },
    },
  },

  active_model: "deepseek/deepseek-v4-pro",

  // ── Tools ────────────────────────────────────────────────────
  // All tools in slife/tools/ are auto-discovered.  Add entries
  // here only to override defaults or disable a tool:
  //
  //   { name: "execute_shell", timeout: 60 },

  // ── MCP servers (minimum bootstrap set) ──────────────────────
  // These three need no API keys — file I/O, web fetch, and search.
  // The agent can add more servers at runtime via mcp_add_server.
  mcp: {
    servers: {
      filesystem: {
        command: "npx",
        args: ["-y", "@modelcontextprotocol/server-filesystem", "."],
        description: "Local filesystem — read, write, list, and search files.",
      },

      fetch: {
        command: "uvx",
        args: ["mcp-server-fetch"],
        description: "Fetch web pages and convert them to markdown.",
      },

      "duckduckgo-search": {
        command: "uvx",
        args: [
          "--with", "duckduckgo-mcp-server[browser]",
          "duckduckgo-mcp-server",
          "--fetch-backend", "auto",
          "--search-backend", "auto",
        ],
        description: "DuckDuckGo web search — no API key needed.",
      },

      // Enable when you have a GITHUB_TOKEN.  anyapi-mcp-server
      // converts any OpenAPI spec into MCP tools — swap --spec and
      // --base-url to connect other REST APIs (Jira, Slack, etc.).
      //
      // disclosure: "lazy" is available for servers that expose many
      // tools (e.g. native MCP servers with one tool per endpoint).
      // Lazy servers connect at startup but don't register their tools
      // until the LLM calls mcp_activate_server.
      //
      // github: {
      //   command: "npx",
      //   args: [
      //     "-y", "anyapi-mcp-server",
      //     "--name", "github",
      //     "--spec", "https://raw.githubusercontent.com/github/rest-api-description/main/descriptions/api.github.com/api.github.com.yaml",
      //     "--base-url", "https://api.github.com",
      //     "--header", "Authorization: Bearer ${GITHUB_TOKEN}",
      //   ],
      //   env: { GITHUB_TOKEN: "${GITHUB_TOKEN}" },
      //   description: "GitHub REST API via anyapi-mcp-server — repos, issues, PRs, users, search.",
      // },
    },
  },

  // ── MQTT broker (A2A remote peers) ─────────────────────────
  // Only active when started with --name <agent-id> on the CLI.
  // The json5 section provides broker connection details only.
  mqtt: {
    broker: {
      host: "localhost",
      port: 1883,
      // command: "mosquitto",   // auto-spawn if not running
    },
    heartbeat_interval: 15,
    heartbeat_timeout: 45,
    task_timeout: 120,
  },

  // ── Subagents (local child processes) ───────────────────────
  // Always available — spawn copies of this agent as worker
  // processes that communicate via stdin/stdout pipes.
  subagent: {
    max_subagents: 5,
    task_timeout: 120,
  },

  // ── Permanent Memory ────────────────────────────────────────
  // Records every conversation like a diary with hybrid keyword
  // (FTS5) + semantic (sqlite-vec) search. Also enables crash
  // recovery — on restart, slife detects interrupted sessions
  // and asks whether to restore or discard.
  //
  // The memory service runs as an independent MCP process
  // (slife-memory), just like slife-mcp. It communicates via
  // stdio (child process) or HTTP.
  //
  // User isolation: --user <name> on CLI. Defaults to "default".
  // Each user gets their own isolated diary namespace.
  //
  // Embeddings: supports two backends:
  //   1. Local GGUF model (offline, no API cost)
  //   2. OpenAI-compatible API (requires api_key)
  memory: {
    enabled: true,

    // SQLite database path
    // db_path: "~/.slife/slife.db",

    // HTTP endpoint for standalone slife-memory server.
    // url: "http://127.0.0.1:9877/mcp",

    // ── Embedding configuration ──────────────────────────────
    embedding: {
      // Backend 1: Local GGUF model (takes priority if gguf_path is set)
      // model: "bge-m3",
      // gguf_path: "C:\\OneDrive\\AI\\hf_KimChen_bge-m3-q4_k_m.gguf",
      // dim: 1024,   // BGE-M3 → 1024; Nomic → 768; OpenAI-small → 1536

      // Backend 2: OpenAI-compatible API (used when gguf_path is not set).
      // API key inherits from models.providers.<first>.api_key.
      // model: "text-embedding-3-small",
    },
  },
}
