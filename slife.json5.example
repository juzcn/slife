{
  // ═══════════════════════════════════════════════════════════════
  // slife Configuration
  // ═══════════════════════════════════════════════════════════════
  // Copy this file to slife.json5 and edit.
  // API keys: use ${ENV_VAR} references — never put real keys here.

  // ── Environment variables ────────────────────────────────────
  // Injected into os.environ so tools and ${VAR} references work.

  env: {
    // SERPER_API_KEY: "${SERPER_API_KEY}",
    // BAIDU_API_KEY: "${BAIDU_API_KEY}",
  },

  // ── Agent defaults ───────────────────────────────────────────

  agent: {
    max_iterations: 10,
  },

  // ── Models ───────────────────────────────────────────────────
  // provider: connection config shared by all models under it.
  //   model:     API model name (doubles as id within provider).
  //   name:      display label shown in the TUI status bar.
  //   reasoning: true → enable thinking mode.
  //   input:     ["text", "image"] → vision support (/file attach).

  models: {
    mode: "merge",

    providers: {
      deepseek: {
        base_url: "https://api.deepseek.com",
        api_key: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",

        models: [
          {
            model: "deepseek-v4-flash",
            name: "DeepSeek V4 Flash",
            reasoning: false,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
          {
            model: "deepseek-v4-pro",
            name: "DeepSeek V4 Pro",
            reasoning: true,
            // reasoning_effort: "high",
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
        ],
      },

      // openai: {
      //   base_url: "https://api.openai.com/v1",
      //   api_key: "${OPENAI_API_KEY}",
      //   api: "openai-completions",
      //   models: [
      //     { model: "gpt-4o", name: "GPT-4o" },
      //   ],
      // },
    },
  },

  active_model: "deepseek/deepseek-v4-pro",

  // ── Tools ────────────────────────────────────────────────────
  // All tools in slife/tools/ are auto-discovered at startup.
  // Add entries here only to override defaults or disable tools.
  // Each entry matches by tool name:
  //
  //   { name: "execute_shell", timeout: 60 },
  //   { name: "list_skills", enabled: false },

  // ── MCP Integration (optional) ────────────────────────────────
  // slife-mcp connects to external MCP servers. Two modes:
  //   Child process — slife auto-starts the wrapper (default).
  //   Standalone HTTP — start manually, slife connects via wrapper.url.
  //
  // Each server: { command, args, env? } — standard MCP format.

  // mcp: {
  //   // wrapper: {
  //   //   url: "http://127.0.0.1:9876/mcp",
  //   // },
  //
  //   servers: {
  //     filesystem: {
  //       command: "npx",
  //       args: ["-y", "@modelcontextprotocol/server-filesystem", "/allowed/path"],
  //     },
  //     serper: {
  //       command: "npx",
  //       args: ["-y", "serper-search-scrape-mcp-server"],
  //       env: {
  //         SERPER_API_KEY: "${SERPER_API_KEY}",
  //       },
  //     },
  //   },
  // },
}
