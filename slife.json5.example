{
  // ═══════════════════════════════════════════════════════════════
  // slife Configuration — OpenClaw-compatible JSON5 format
  // ═══════════════════════════════════════════════════════════════
  // API keys: set as environment variables, reference with ${VAR}.
  //            Never put real keys in this file — use ${ENV_VAR}.

  // ── Environment variables ────────────────────────────────────
  // Injected into os.environ so tools and shell commands can
  // reference them via ${VAR} syntax.

  env: {
    // SERPER_API_KEY: "${SERPER_API_KEY}",
    // BAIDU_API_KEY: "${BAIDU_API_KEY}",
  },

  // ── Agent defaults ───────────────────────────────────────────

  agent: {
    max_iterations: 10,
  },

  // ── Models ───────────────────────────────────────────────────
  // provider/<id>: connection config shared by all models under it.
  // model: API model name (doubles as local identifier within provider).
  // name:  display label shown in the TUI status bar.
  // reasoning: true → enable thinking/reasoning mode (DeepSeek V4).
  // reasoning_effort: optional — "low" | "medium" | "high" | "xhigh" | "max".
  // input: ["text", "image"] → supports vision (image attachment via /file).

  models: {
    mode: "merge",

    providers: {
      deepseek: {
        base_url: "https://api.deepseek.com",
        api_key: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",

        models: [
          {
            model: "deepseek-v4-flash",
            name: "DeepSeek V4 Flash",
            reasoning: false,
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
          {
            model: "deepseek-v4-pro",
            name: "DeepSeek V4 Pro",
            reasoning: true,
            // reasoning_effort: "high",
            input: ["text", "image"],
            context_window: 131072,
            max_tokens: 8192,
            temperature: 0.7,
            top_p: 1.0,
          },
        ],
      },

      // Example: OpenAI provider
      // openai: {
      //   base_url: "https://api.openai.com/v1",
      //   api_key: "${OPENAI_API_KEY}",
      //   api: "openai-completions",
      //   models: [
      //     { model: "gpt-4o", name: "GPT-4o" },
      //   ],
      // },
    },
  },

  active_model: "deepseek/deepseek-v4-pro",

  // ── Tools ────────────────────────────────────────────────────
  // Each entry maps to a Tool subclass via slife/tools/factory.py.
  //
  //   platform — get_shell_command (OS-correct shell syntax)
  //   shell    — execute_shell (run commands with timeout)
  //   skill    — list_skills + use_skill (on-demand documentation)

  tools: [
    { type: "platform" },
    { type: "shell", timeout: 30 },
    { type: "skill", skills_dir: "skills" },
  ],

  // ── MCP Integration (optional) ────────────────────────────────
  // The slife-mcp wrapper manages connections to external MCP
  // servers. Two modes:
  //
  //   Child process (default): slife auto-starts the wrapper.
  //     Uses wrapper.command + wrapper.args to spawn.
  //
  //   Standalone HTTP: you start the wrapper manually, slife
  //     connects to it. Set wrapper.url to the MCP endpoint.
  //     Start the wrapper: python -m slife_mcp.server --transport http
  //
  // Each server entry uses standard MCP format:
  //   command — executable to run
  //   args    — command-line arguments
  //   env     — optional environment variables for the server process

  // mcp: {
  //   // wrapper.url — slife probes this URL first, falls back to
  //   // child process. The wrapper server reads it via --config:
  //   //   python -m slife_mcp.server --config slife.json5
  //   //
  //   // wrapper: {
  //   //   url: "http://127.0.0.1:9876/mcp",
  //   // },
  //
  //   servers: {
  //     filesystem: {
  //       command: "npx",
  //       args: ["-y", "@modelcontextprotocol/server-filesystem", "/allowed/path"],
  //     },
  //     serper: {
  //       command: "npx",
  //       args: ["-y", "serper-search-scrape-mcp-server"],
  //       env: {
  //         SERPER_API_KEY: "${SERPER_API_KEY}",
  //       },
  //     },
  //   },
  // },
}
